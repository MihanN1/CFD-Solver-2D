{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake configure VS2026 x64",
            "type": "shell",
            "command": "cmake -S . -B build -G \"Visual Studio 18 2026\" -A x64",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake build Release",
            "type": "shell",
            "command": "cmake --build build --config Release",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake install Release",
            "type": "shell",
            "command": "cmake --install build --config Release --prefix install",
            "group": "build",
            "problemMatcher": []
        }
    ]
}